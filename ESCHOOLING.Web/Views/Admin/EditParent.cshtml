@model ECOMSYSTEM.Shared.Models.ApplicationUser
@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Edit Parent | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">
</head>

<body class="text-left">

    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Edit Parent</a></li>
                <li>Admin</li>
            </ul>
        </div>
        <div class="col-lg-6">
            <form asp-action="EditParent" method="post">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="UserType" />
                <div class="form-group">
                    <label asp-for="Username">Name</label>
                    <input class="form-control form-control-rounded" asp-for="Username" required>
                </div>
                <div class="form-group">
                    <label asp-for="Email">Email address</label>
                    <input class="form-control form-control-rounded" asp-for="Email" required>
                </div>
                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <div class="password-field">
                        <input class="form-control form-control-rounded" asp-for="Password" required>
                        <i class="i-Eye password-toggle-icon" title="Show password" onclick="TogglePasswordVisibility('Password', this);"></i>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="MobileNo">Mobile No</label>
                    <input class="form-control form-control-rounded" asp-for="MobileNo" required>
                </div>
                <div class="form-group">
                    <label asp-for="Address">Address</label>
                    <input class="form-control form-control-rounded" asp-for="Address" required>
                </div>
                <div class="form-group">
                    <label asp-for="ChildStudentId">Child (Student)</label>
                    <select class="form-control form-control-rounded" asp-for="ChildStudentId">
                        <option value="">-- No child linked yet --</option>
                        @foreach (var student in (List<ECOMSYSTEM.Shared.Models.ApplicationUser>)ViewBag.Students)
                        {
                            <option value="@student.UserId">@student.Username (@student.Email)</option>
                        }
                    </select>
                </div>
                <div class="form-group form-check">
                    <input type="checkbox" class="form-check-input" asp-for="IsActiveChecked">
                    <label class="form-check-label" asp-for="IsActiveChecked">Active</label>
                </div>
                <button class="btn btn-primary btn-rounded mt-2" type="submit">Save Changes</button>
            </form>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
