@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Add Event | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/EventsDoc.js"></script>

</head>


<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Add Event</a></li>
                <li>Administrator</li>
            </ul>
        </div>
        <div class="col-lg-8">
            <div class="form-panel">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="eventName">Title</label>
                        <input class="form-control form-control-rounded" id="eventName" name="eventName" type="text" placeholder="e.g. Annual Sports Day" required>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="grade">Audience</label>
                        <select class="form-control form-control-rounded" id="grade" name="grade" required>
                            <option value="" selected>All grades</option>
                            <option value="9">Grade 9</option>
                            <option value="10">Grade 10</option>
                            <option value="11">Grade 11</option>
                            <option value="12">Grade 12</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea class="form-control form-control-rounded" id="description" name="description" rows="4" placeholder="e.g. Join us for the annual sports day at the main ground" required></textarea>
                </div>
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label for="date">Date</label>
                        <input class="form-control form-control-rounded" id="date" name="date" type="date" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="time">Time</label>
                        <input class="form-control form-control-rounded" id="time" name="time" type="time" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label for="place">Place</label>
                        <input class="form-control form-control-rounded" id="place" name="place" type="text" placeholder="e.g. Main Auditorium" required>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-rounded" type="button" onclick="SaveEventBtn_Click();">Add Event</button>
                    <button class="btn btn-outline-secondary btn-rounded" type="button" onclick="ClearEventForm();">Cancel</button>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
