@model IEnumerable<ESCHOOLING.Shared.Models.Events>
@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Manage Events | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet" />
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet" />
    <link href="../../dist-assets/css/plugins/perfect-scrollbar.min.css" rel="stylesheet" />
</head>

<body class="text-left">

    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Manage Events</a></li>
                <li>Admin</li>
                <li>
                    <a class="btn btn-primary float-right" asp-action="AddEvent">Add Event</a>
                </li>
            </ul>
        </div>
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info">@TempData["Message"]</div>
        }
        <div class="col-lg-12">
            <div class="row">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Event Name</th>
                                <th scope="col">Description</th>
                                <th scope="col">Date</th>
                                <th scope="col">Time</th>
                                <th scope="col">Place</th>
                                <th scope="col">Grade</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th scope="row">@Html.DisplayFor(modelItem => item.Id)</th>
                                    <td>@Html.DisplayFor(modelItem => item.EventName)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Date)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Time)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Place)</td>
                                    <td>@(item.Grade?.ToString() ?? "All grades")</td>
                                    <td>
                                        <a class="btn btn-success" asp-action="EditEvent" asp-route-id="@item.Id" type="button"><i class="nav-icon i-Pen-2"></i></a>
                                        <form asp-action="DeleteEvent" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Permanently delete this event?');">
                                            <button class="btn btn-danger" type="submit"><i class="nav-icon i-Close-Window"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>
</body>

</html>
