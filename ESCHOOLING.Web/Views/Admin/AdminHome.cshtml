@model ESCHOOLING.Shared.Models.AdminDashboardModel
@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Dashboard </title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet" />
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet" />
    <link href="../../dist-assets/css/plugins/perfect-scrollbar.min.css" rel="stylesheet" />
    <style>
        .stat-card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(20, 15, 30, .07);
        }

        .stat-card .card-body {
            display: flex;
            align-items: center;
            padding: 1.5rem;
        }

        .stat-icon-badge {
            width: 52px;
            height: 52px;
            min-width: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
        }

        .stat-icon-badge i {
            color: #fff;
            font-size: 24px;
        }

        .stat-label {
            color: #70657b;
            margin: 0 0 2px;
            font-size: 13px;
        }

        .stat-value {
            color: #262129;
            margin: 0;
            font-size: 26px;
            font-weight: 700;
        }
    </style>
</head>

<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Dashboard</a></li>
                <li>Admin</li>
            </ul>
        </div>
        <div class="alert alert-light border mt-2 mb-3">
            <strong>Welcome back, @User.Identity?.Name!</strong>
        </div>
        <div class="col-lg-12">
            <div class="row">
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card stat-card mb-4">
                        <div class="card-body">
                            <div class="stat-icon-badge" style="background-color:#663399;">
                                <i class="i-Add-User"></i>
                            </div>
                            <div>
                                <p class="stat-label">Students</p>
                                <p class="stat-value">@Model.StudentCount</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card stat-card mb-4">
                        <div class="card-body">
                            <div class="stat-icon-badge" style="background-color:#2196F3;">
                                <i class="i-Financial"></i>
                            </div>
                            <div>
                                <p class="stat-label">Parents</p>
                                <p class="stat-value">@Model.ParentCount</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card stat-card mb-4">
                        <div class="card-body">
                            <div class="stat-icon-badge" style="background-color:#0f9670;">
                                <i class="i-Teacher"></i>
                            </div>
                            <div>
                                <p class="stat-label">Teachers</p>
                                <p class="stat-value">@Model.TeacherCount</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card stat-card mb-4">
                        <div class="card-body">
                            <div class="stat-icon-badge" style="background-color:#c25f18;">
                                <i class="i-Consulting"></i>
                            </div>
                            <div>
                                <p class="stat-label">Counselors</p>
                                <p class="stat-value">@Model.CounselorCount</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 col-md-12">
                    <div class="card o-hidden mb-4">
                        <div class="card-body">
                            <h4 class="card-title">New Registrations</h4>
                            <p class="text-muted">Last 6 months</p>
                            <div id="registrationTrendChart" style="height:300px"></div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-12">
                    <div class="card o-hidden mb-4">
                        <div class="card-body">
                            <h4 class="card-title">School Attendance Rate</h4>
                            <p class="text-muted">Last 6 months</p>
                            <div id="attendanceRateChart" style="height:300px"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>

@section Scripts {
    <script>
        $(document).ready(function () {
            var registrationMonths = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationMonths));
            var registrationCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationCounts));
            var attendanceMonths = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AttendanceMonths));
            var attendanceRates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AttendanceRates));

            var gridlineStyle = { lineStyle: { color: '#e1e0d9', type: 'solid' } };
            var axisTextColor = '#70657b';

            var registrationEl = document.getElementById('registrationTrendChart');
            if (registrationEl) {
                var registrationChart = echarts.init(registrationEl);
                registrationChart.setOption({
                    color: ['#CB3066'],
                    grid: { left: '3%', right: '8%', bottom: '3%', top: '10%', containLabel: true },
                    tooltip: { trigger: 'axis', backgroundColor: 'rgba(0, 0, 0, .8)' },
                    xAxis: { type: 'category', data: registrationMonths, boundaryGap: false, axisLabel: { color: axisTextColor }, axisLine: { lineStyle: { color: '#c3c2b7' } } },
                    yAxis: { type: 'value', minInterval: 1, axisLabel: { color: axisTextColor }, splitLine: gridlineStyle },
                    series: [{
                        name: 'New Registrations',
                        type: 'line',
                        smooth: true,
                        data: registrationCounts,
                        symbolSize: 8,
                        endLabel: { show: true, formatter: '{c}', color: '#52514e', fontWeight: 600 },
                        areaStyle: { color: 'rgba(203, 48, 102, .1)' },
                        lineStyle: { color: '#CB3066', width: 2 },
                        itemStyle: { color: '#CB3066' }
                    }]
                });
                $(window).on('resize', function () {
                    setTimeout(function () { registrationChart.resize(); }, 500);
                });
            }

            var attendanceEl = document.getElementById('attendanceRateChart');
            if (attendanceEl) {
                var attendanceChart = echarts.init(attendanceEl);
                attendanceChart.setOption({
                    color: ['#0f9670'],
                    grid: { left: '3%', right: '8%', bottom: '3%', top: '10%', containLabel: true },
                    tooltip: { trigger: 'axis', backgroundColor: 'rgba(0, 0, 0, .8)', valueFormatter: function (value) { return value + '%'; } },
                    xAxis: { type: 'category', data: attendanceMonths, boundaryGap: false, axisLabel: { color: axisTextColor }, axisLine: { lineStyle: { color: '#c3c2b7' } } },
                    yAxis: { type: 'value', min: 0, max: 100, axisLabel: { formatter: '{value}%', color: axisTextColor }, splitLine: gridlineStyle },
                    series: [{
                        name: 'Attendance Rate',
                        type: 'line',
                        smooth: true,
                        data: attendanceRates,
                        symbolSize: 8,
                        endLabel: { show: true, formatter: '{c}%', color: '#52514e', fontWeight: 600 },
                        areaStyle: { color: 'rgba(15, 150, 112, .1)' },
                        lineStyle: { color: '#0f9670', width: 2 },
                        itemStyle: { color: '#0f9670' }
                    }]
                });
                $(window).on('resize', function () {
                    setTimeout(function () { attendanceChart.resize(); }, 500);
                });
            }
        });
    </script>
}
