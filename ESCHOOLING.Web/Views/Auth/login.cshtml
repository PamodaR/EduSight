@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>EduSight | Sign In</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/LoginDoc.js"></script>
</head>
<body>
    <div class="auth-split">
        <div class="auth-split-image"></div>
        <div class="auth-split-form">
            <div class="auth-form-inner">
                <div class="auth-logo">
                    <h2 class="text-primary font-weight-bold m-0" style="letter-spacing: -1px; font-size: 2rem;">EduSight</h2>
                    <p class="text-muted" style="font-size: 0.85rem; font-weight: 500; margin-top: 4px;">Smart School Management System</p>
                </div>
                <h1>Login</h1>
                <div class="form-group">
                    <label for="email">Email address</label>
                    <input class="form-control" id="email" name="email" type="email" placeholder="Enter your email">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input class="form-control" id="password" name="password" type="password" placeholder="Enter your password">
                </div>
                <button class="btn btn-rounded btn-primary btn-block mt-4" onclick="LoginBtn_Click();">Login</button>
            </div>
        </div>
    </div>
</body>
</html>
