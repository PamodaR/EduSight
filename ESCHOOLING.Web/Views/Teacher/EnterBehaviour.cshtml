@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Enter Behaviour | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/EnterBehaviour.js"></script>

</head>


<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Enter Behaviour</a></li>
                <li>Teacher</li>
            </ul>
        </div>
        <div class="col-lg-8">
            <div class="form-panel">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="studentId">Student</label>
                        <select class="form-control form-control-rounded" id="studentId" name="studentId" required>
                            <option value="" selected disabled>Select student</option>
                            @foreach (var student in (List<ECOMSYSTEM.Shared.Models.ApplicationUser>)ViewBag.Students)
                            {
                                <option value="@student.UserId">@student.Username (@student.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="Date">Date</label>
                        <input class="form-control form-control-rounded" id="Date" name="Date" type="date" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="BehaviourType">Behaviour Type</label>
                        <select class="form-control form-control-rounded" id="BehaviourType" name="BehaviourType" required>
                            <option value="" selected disabled>Select behaviour type</option>
                            <option value="Positive">Positive</option>
                            <option value="Negative">Negative</option>
                            <option value="Neutral">Neutral</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label for="Description">Description</label>
                        <textarea class="form-control form-control-rounded" id="Description" name="Description" rows="4" placeholder="Describe the behaviour note" required></textarea>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-rounded" onclick="EnterBehaviourBtn_Click();"> Save Behaviour</button>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
