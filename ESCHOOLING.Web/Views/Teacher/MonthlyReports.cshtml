@model ESCHOOLING.Shared.Models.MonthlyReportsViewModel
@{
    Layout = "_TeacherLayout";
    var monthOptions = Enumerable.Range(0, 12)
        .Select(i => DateTime.Today.AddMonths(-i))
        .Select(d => new { Value = d.ToString("yyyy-MM"), Label = d.ToString("MMMM yyyy") });
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Monthly Reports | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet" />
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet" />
    <link href="../../dist-assets/css/plugins/perfect-scrollbar.min.css" rel="stylesheet" />
</head>

<body class="text-left">

    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Monthly Reports</a></li>
                <li>Teacher</li>
            </ul>
            <select class="form-control form-control-rounded mt-2 col-lg-2" id="reportMonth" name="reportMonth">
                @foreach (var m in monthOptions)
                {
                    <option value="@m.Value" selected="@(m.Value == Model.SelectedMonth ? "selected" : null)">@m.Label</option>
                }
            </select>
            &nbsp;&nbsp;
            <button class="btn btn-primary btn-block btn-rounded mt-2 col-lg-1 float-right" onclick="window.location.href = '/Teacher/MonthlyReports?date=' + document.getElementById('reportMonth').value;"> View</button>
        </div>

        <div class="col-lg-12">
            <div class="row">
                <div class="col-12 d-flex justify-content-between align-items-center">
                    <h4>Attendance</h4>
                    <input type="button" class="btn btn-success" value="Download Excel" onclick="location.href='@Url.Action("ExportToExcel", "Teacher", new { id = 0L, date = Model.SelectedMonth })'" />
                </div>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th scope="col">Student Id</th>
                                <th scope="col">Attendance</th>
                                <th scope="col">Status</th>
                                <th scope="col">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.AttendanceEntries)
                            {
                                <tr>
                                    <td>@Html.DisplayFor(modelItem => item.StudentId)</td>
                                    <td>
                                        @if (item.IsPresent == true)
                                        {
                                            <span class="badge badge-success">Present</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">Absent</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.IsActive == true)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">Not Active</span>
                                        }
                                    </td>
                                    <td>@Html.DisplayFor(modelItem => item.Date)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-between align-items-center">
                    <h4>Behaviour</h4>
                    <input type="button" class="btn btn-success" value="Download Excel" onclick="location.href='@Url.Action("ExportBehaviourToExcel", "Teacher", new { date = Model.SelectedMonth })'" />
                </div>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th scope="col">Student</th>
                                <th scope="col">Behaviour Type</th>
                                <th scope="col">Description</th>
                                <th scope="col">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BehaviourEntries)
                            {
                                <tr>
                                    <td>@Html.DisplayFor(modelItem => item.StudentName)</td>
                                    <td>@Html.DisplayFor(modelItem => item.BehaviourType)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                    <td>@Html.DisplayFor(modelItem => item.CreatedDate)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>
</body>

</html>
