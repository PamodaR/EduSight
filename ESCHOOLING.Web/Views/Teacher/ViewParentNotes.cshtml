@model IEnumerable<ESCHOOLING.Shared.Models.ParentNote>
@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>View Parent Notes | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet" />
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet" />
    <link href="../../dist-assets/css/plugins/perfect-scrollbar.min.css" rel="stylesheet" />

    <!-- Sweet alert -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/ViewParentNotes.js"></script>
</head>

<body class="text-left">

    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">View Parent Notes</a></li>
                <li>Teacher</li>
            </ul>
        </div>
        <div class="col-lg-12">
            <div class="row">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th scope="col">Student</th>
                                <th scope="col">Parent</th>
                                <th scope="col">Note</th>
                                <th scope="col">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var noteText = item.NoteText ?? string.Empty;
                                var truncatedNote = noteText.Length > 60 ? noteText.Substring(0, 60) + "..." : noteText;
                                <tr class="parent-note-row" style="cursor:pointer" title="Click to view full note"
                                    data-student="@item.StudentName"
                                    data-parent="@item.ParentName"
                                    data-note="@noteText"
                                    data-date="@item.CreatedDate">
                                    <td>
                                        @Html.DisplayFor(modelItem => item.StudentName)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.ParentName)
                                    </td>
                                    <td>
                                        @truncatedNote
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.CreatedDate)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>
</body>

</html>
