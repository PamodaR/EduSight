@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Post Homework | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/HomeworkDoc.js"></script>

</head>


<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Post Homework</a></li>
                <li>Teacher</li>
            </ul>
        </div>
        <div class="col-lg-8">
            <div class="form-panel">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="grade">Grade</label>
                        <select class="form-control form-control-rounded" id="grade" name="grade" required>
                            <option value="" selected disabled>Select grade</option>
                            <option value="9">9</option>
                            <option value="10">10</option>
                            <option value="11">11</option>
                            <option value="12">12</option>
                        </select>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="subject">Subject</label>
                        <input class="form-control form-control-rounded" id="subject" name="subject" type="text" placeholder="e.g. Mathematics" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea class="form-control form-control-rounded" id="description" name="description" rows="4" placeholder="e.g. Complete exercises 1-10 on page 42" required></textarea>
                </div>
                <div class="form-group">
                    <label for="dueDate">Due Date</label>
                    <input class="form-control form-control-rounded" id="dueDate" name="dueDate" type="date" required>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-rounded" type="button" onclick="SaveHomeworkBtn_Click();">Post Homework</button>
                    <button class="btn btn-outline-secondary btn-rounded" type="button" onclick="ClearHomeworkForm();">Cancel</button>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
