@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Add Student | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/RegisterDoc.js"></script>

</head>


<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Add Students</a></li>
                <li>Teacher</li>
            </ul>
        </div>
        <div class="col-lg-8">
            <div class="form-panel">
                <div class="form-group">
                    <label for="userName">Name</label>
                    <input class="form-control form-control-rounded" id="userName" name="userName" type="text" placeholder="e.g. Nimal Silva" autocomplete="off" required>
                </div>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="email">Email address</label>
                        <input class="form-control form-control-rounded" id="email" name="email" type="email" placeholder="name@school.edu" required>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="password">Password</label>
                        <div class="password-field">
                            <input class="form-control form-control-rounded" id="password" name="password" type="password" placeholder="••••••••" required>
                            <i class="i-Eye password-toggle-icon" title="Show password" onclick="TogglePasswordVisibility('password', this);"></i>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="MobileNo">Mobile No</label>
                        <input class="form-control form-control-rounded" id="mobileNo" name="mobileNo" type="text" placeholder="07X XXX XXXX" required>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="Address">Address</label>
                        <input class="form-control form-control-rounded" id="address" name="address" type="text" placeholder="Street, city" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="grade">Grade</label>
                    <select class="form-control form-control-rounded" id="grade" name="grade" required>
                        <option value="" selected disabled>Select grade</option>
                        <option value="9">9</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                    </select>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-rounded" type="button" onclick="StudentRegistrationBtn_Click(2);">Add</button>
                    <button class="btn btn-outline-secondary btn-rounded" type="button" onclick="Clear();">Cancel</button>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
