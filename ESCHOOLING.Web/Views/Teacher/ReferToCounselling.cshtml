@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Refer Student to Counselling | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sweet alert -->
    <script src="~/js/plugins/sweetalert/sweetalert.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/ReferToCounselling.js"></script>

</head>


<body class="text-left">

    <!-- ============ Body content start ============= -->
    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Refer Student to Counselling</a></li>
                <li>Teacher</li>
            </ul>
        </div>
        <div class="col-lg-8">
            <div class="form-panel">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="studentId">Student</label>
                        <select class="form-control form-control-rounded" id="studentId" name="studentId" required>
                            <option value="" selected disabled>Select student</option>
                            @foreach (var student in (List<ECOMSYSTEM.Shared.Models.ApplicationUser>)ViewBag.Students)
                            {
                                <option value="@student.UserId">@student.Username (@student.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="counselorId">Counsellor</label>
                        <select class="form-control form-control-rounded" id="counselorId" name="counselorId" required>
                            <option value="" selected disabled>Select counsellor</option>
                            @foreach (var counselor in (List<ECOMSYSTEM.Shared.Models.Counselor>)ViewBag.Counselors)
                            {
                                <option value="@counselor.CounselorId">@counselor.Name (@counselor.Specialization)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label for="Reason">Reason</label>
                        <textarea class="form-control form-control-rounded" id="Reason" name="reason" rows="4" placeholder="Briefly describe why this student is being referred" required></textarea>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-rounded" onclick="ReferToCounsellingBtn_Click();"> Submit Referral</button>
                </div>
            </div>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
