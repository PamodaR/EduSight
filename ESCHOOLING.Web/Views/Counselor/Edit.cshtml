@model ECOMSYSTEM.Shared.Models.Counselor
@{
    Layout = "_TeacherLayout";
}

<!DOCTYPE html>
<html lang="en" dir="">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Edit Counselor | EduSight</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,400i,600,700,800,900" rel="stylesheet">
    <link href="../../dist-assets/css/themes/lite-purple.min.css" rel="stylesheet">
</head>

<body class="text-left">

    <div class="main-content">
        <div class="breadcrumb">
            <ul>
                <li><a href="">Edit Counselor</a></li>
                <li>Admin</li>
            </ul>
        </div>
        <div class="col-lg-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="CounselorId" />
                <div class="form-group">
                    <label asp-for="Name">Name</label>
                    <input class="form-control form-control-rounded" asp-for="Name" required>
                </div>
                <div class="form-group">
                    <label asp-for="Email">Email address</label>
                    <input class="form-control form-control-rounded" asp-for="Email" required>
                </div>
                <div class="form-group">
                    <label asp-for="MobileNo">Mobile No</label>
                    <input class="form-control form-control-rounded" asp-for="MobileNo" required>
                </div>
                <div class="form-group">
                    <label asp-for="Address">Address</label>
                    <input class="form-control form-control-rounded" asp-for="Address" required>
                </div>
                <div class="form-group">
                    <label asp-for="Specialization">Specialization</label>
                    <input class="form-control form-control-rounded" asp-for="Specialization">
                </div>
                <div class="form-group form-check">
                    <input type="checkbox" class="form-check-input" asp-for="IsActiveChecked">
                    <label class="form-check-label" asp-for="IsActiveChecked">Active</label>
                </div>
                <button class="btn btn-primary btn-rounded mt-2" type="submit">Save Changes</button>
            </form>
        </div>
        <!-- end of main-content -->
    </div>

</body>

</html>
